# Application
APP_NAME=NexusIQ AI Service
APP_ENV=development
DEBUG=true
PORT=8000
HOST=0.0.0.0

# PostgreSQL
PG_DSN=postgresql+asyncpg://postgres:password@localhost:5432/nexusiq

# MongoDB
MONGO_URI=mongodb://localhost:27017/nexusiq

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_REGION=us-east-1
AWS_S3_BUCKET=nexusiq-documents

# OpenAI
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4-turbo-preview
EMBEDDING_MODEL=text-embedding-ada-002

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=nexusiq_docs

# ML Settings
DEFAULT_FORECAST_MODEL=auto
MAX_FORECAST_HORIZON=365
CHURN_THRESHOLD=0.5
RISK_SENSITIVITY=medium

# Security
SECRET_KEY=your_secret_key_for_ai_service
BACKEND_SERVICE_KEY=nexusiq_internal_key
